{
  "functions": {
    "api/analyze.js": {
      "maxDuration": 60
    },
    "api/clients.js": {
      "maxDuration": 15
    },
    "api/auth.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
